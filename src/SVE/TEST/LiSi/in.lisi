# ReaxFF benchmark: Li-Si alloy system
# Based on 16-atom unit cell generated by pymatgen

units		real
atom_style	charge
dimension   3
boundary    p p p

variable x index 1
variable y index 1
variable z index 1

variable a_const equal 6.221210

lattice custom ${a_const} &
    a1 1.0 0.0 0.0 &
    a2 0.0 1.0 0.0 &
    a3 0.0 0.0 1.0 &
    basis 0.0000 0.0000 0.5000 & 
    basis 0.2500 0.7500 0.2500 &
    basis 0.0000 0.5000 0.0000 &
    basis 0.2500 0.2500 0.7500 &
    basis 0.5000 0.0000 0.0000 &
    basis 0.7500 0.7500 0.7500 &
    basis 0.5000 0.5000 0.5000 &
    basis 0.7500 0.2500 0.2500 &
    basis 0.2500 0.2500 0.2500 & 
    basis 0.5000 0.0000 0.5000 &
    basis 0.2500 0.7500 0.7500 &
    basis 0.5000 0.5000 0.0000 &
    basis 0.7500 0.2500 0.7500 &
    basis 0.0000 0.0000 0.0000 &
    basis 0.7500 0.7500 0.2500 &
    basis 0.0000 0.5000 0.5000

region      sim_box block 0 ${x} 0 ${y} 0 ${z}
create_box  2 sim_box

create_atoms 1 box &
    basis 1 1 basis 2 1 basis 3 1 basis 4 1 &
    basis 5 1 basis 6 1 basis 7 1 basis 8 1 &
    basis 9 2 basis 10 2 basis 11 2 basis 12 2 &
    basis 13 2 basis 14 2 basis 15 2 basis 16 2

mass 1 6.9410   # Li
mass 2 28.0855  # Si

pair_style	reaxff NULL safezone 1.4
pair_coeff	* * ffield.LiSiC Li Si

neighbor	2.0 bin
neigh_modify	every 20 delay 20 check yes one 4000 page 100000

timestep	0.1
fix		1 all nve
fix		2 all qeq/reaxff 1 0.0 10.0 1.0e-6 reaxff cg_algo 1

velocity	all create 300.0 9999
thermo		10
thermo_style	custom step temp ke pe pxx pyy pzz etotal cpu

run		100