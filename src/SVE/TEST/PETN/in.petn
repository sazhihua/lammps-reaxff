    # --- basis end ---

variable x index 1
variable y index 1
variable z index 1
region sim_box block 0 $x 0 $y 0 $z
create_box 4 sim_box

create_atoms 1 box &
    basis 1 4     basis 2 3     basis 3 3     basis 4 3 &
    basis 5 2     basis 6 2     basis 7 1     basis 8 4 &
    basis 9 3     basis 10 3     basis 11 3     basis 12 2 &
    basis 13 2     basis 14 1     basis 15 4     basis 16 3 &
    basis 17 3     basis 18 3     basis 19 2     basis 20 2 &
    basis 21 1     basis 22 4     basis 23 3     basis 24 3 &
    basis 25 3     basis 26 2     basis 27 2     basis 28 1 &
    basis 29 1     basis 30 1     basis 31 4     basis 32 3 &
    basis 33 3     basis 34 3     basis 35 2     basis 36 2 &
    basis 37 1     basis 38 4     basis 39 3     basis 40 3 &
    basis 41 3     basis 42 2     basis 43 2     basis 44 1 &
    basis 45 4     basis 46 3     basis 47 3     basis 48 3 &
    basis 49 2     basis 50 2     basis 51 1     basis 52 4 &
    basis 53 3     basis 54 3     basis 55 3     basis 56 2 &
    basis 57 2     basis 58 1 

mass 1 12.0000
mass 2 1.0080
mass 3 15.9990
mass 4 14.0000

velocity        all create 300.0 9999

pair_style      reaxff NULL safezone 1.4
pair_coeff      * * ffield.reax C H O N

neigh_modify    one 4000 page 100000

timestep        0.1

fix             1 all nve 
fix             2 all qeq/reaxff 1 0.0 10.0 1.0e-6 reaxff

thermo          10
thermo_style    custom step temp ke pe pxx pyy pzz etotal press

dump            1 all custom 10 dump.PETN.lammpstrj id type x y z q

run             100
