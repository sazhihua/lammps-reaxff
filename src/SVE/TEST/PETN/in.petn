# ReaxFF benchmark: simulation of PETN crystal, lattice version

units           real
atom_style      charge

variable a equal 9.491065
variable c equal 6.991230

lattice custom 1.0 &
    a1 $a 0.0 0.0 &
    a2 0.0 $a 0.0 &
    a3 0.0 0.0 $c &
    basis 0.182521 0.487828 0.127638 &
