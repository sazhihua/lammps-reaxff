# ReaxFF benchmark: simulation of PETN crystal, replicated unit cell

units		real
atom_style	charge

read_data	data.reax

replicate	7 8 10
#replicate	14 16 20
#replicate	14 16 80

velocity	all create 300.0 9999


pair_style	reaxff NULL
#pair_style	reaxff control.reaxff.petn
#pair_style	reaxff NULL list/blocking no

pair_coeff      * * ffield.reax C H O N

neigh_modify one 4000 page 100000

timestep	0.1
fix		1 all nve 
fix             2 all qeq/reaxff 1 0.0 10.0 1.0e-6 reaxff

thermo	10
#thermo_style	custom step temp ke pe pxx pyy pzz etotal
thermo_style	custom step temp ke pe pxx pyy pzz etotal press

run		100
